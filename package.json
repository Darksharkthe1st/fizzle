{
  "name": "fizzle",
  "version": "1.0.7",
  "description": "Fizzle desktop app",
  "author": "Darksharkthe1st",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "publish": "electron-builder --publish always"
  },
  "build": {
    "appId": "com.fizzle.app",
    "productName": "Fizzle",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "shared.jsx",
      "avenue-fuze.jsx",
      "avenue-habits.jsx",
      "fz-settings.jsx",
      "app.jsx",
      "fizzle logo clean.png"
    ],
    "icon": "assets/icon.png",
    "publish": {
      "provider": "github",
      "owner": "Darksharkthe1st",
      "repo": "fizzle"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": {
        "target": "dmg",
        "arch": [
          "x64",
          "arm64"
        ]
      }
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8"
  },
  "allowScripts": {
    "electron@35.7.5": true
  }
}
